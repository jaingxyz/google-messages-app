{
  "name": "google-messages-mcp",
  "version": "1.0.0",
  "description": "Google Messages for web as a persistent-session macOS app + an MCP server to send/read/search/delete texts.",
  "type": "module",
  "bin": {
    "google-messages-mcp": "src/server.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "app": "node src/app.mjs",
    "mcp": "node src/server.mjs",
    "lint": "for f in src/*.mjs tools/*.mjs; do node --check \"$f\" || exit 1; done",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "postinstall": "playwright install chromium",
    "prepare": "husky"
  },
  "author": "",
  "license": "AGPL-3.0-or-later",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "playwright": "^1.61.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "prettier": "^3.9.1"
  }
}
